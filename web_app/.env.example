# Web app environment variables (copy to .env and fill in)
PORT=3000

# Cosmos DB
COSMOS_ENDPOINT=https://<your-account>.documents.azure.com:443/
COSMOS_KEY=<your-primary-key>
COSMOS_DATABASE=newsfeed
COSMOS_CONTAINER=articles

# Optional: JSON array describing the feeds (mirrors the Functions setting).
# When unset, the web app falls back to the defaults baked into the spec.
# RSS_FEEDS=[{"index":0,"category":"Foundry","url":"..."}]
